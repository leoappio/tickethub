# Copy to ".env" (git-ignored) and fill in real values locally.
# In production these come from the cloud secret manager, never from a file.
POSTGRES_USER=tickethub
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=tickethub

# JWT signing key — generate a fresh 256-bit key, e.g.:
#   openssl rand -base64 48
JWT_KEY=change-me-with-a-random-256-bit-key
