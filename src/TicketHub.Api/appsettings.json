{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [ "https://app.tickethub.example" ]
  },
  "Jwt": {
    "Issuer": "tickethub",
    "Audience": "tickethub-clients",
    "AccessMinutes": 60,
    "RefreshDays": 7
  }
}
